# Environment Configuration
NODE_ENV=production
PORT=3001

# JWT Configuration (Generate strong secrets with: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-at-least-32-characters-long
JWT_REFRESH_EXPIRES_IN=7d

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/nextgen_outreach

# Admin Credentials
ADMIN_EMAIL=tshepo@nextgenoutreach.co.za
ADMIN_PASSWORD=your-secure-admin-password-at-least-8-characters

# Email Configuration (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=noreply@nextgenoutreach.com

# Redis Configuration
REDIS_URL=redis://localhost:6379

# AWS Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name

# PayFast Configuration
PAYFAST_MERCHANT_ID=your-payfast-merchant-id
PAYFAST_MERCHANT_KEY=your-payfast-merchant-key
PAYFAST_PASSPHRASE=your-payfast-passphrase
PAYFAST_MODE=production

# GoLogin Configuration
GOLOGIN_API_TOKEN=your-gologin-api-token
GOLOGIN_PROFILE_ID=your-gologin-profile-id

# BitBrowser Configuration
BIT_BROWSER_API_URL=https://api.bitbrowser.com
BIT_BROWSER_API_KEY=your-bitbrowser-api-key

# Security Configuration
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# CORS Configuration
CORS_ORIGIN=https://nextgenoutreach.co.za

# Session Configuration
SESSION_SECRET=your-session-secret-at-least-32-characters-long
SESSION_MAX_AGE=86400000

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Firebase Admin SDK (for custom claims)
# Generate from: Firebase Console > Project Settings > Service Accounts > Generate new private key
# Paste the entire JSON as a single-line string
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"..."}'

# 2FA Configuration
TOTP_ISSUER=NextGenOutreach

# File Upload Configuration
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,application/pdf
