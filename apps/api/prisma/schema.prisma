// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String   @map("password_hash")
  role            UserRole
  status          UserStatus @default(PENDING)
  twoFaSecret     String?  @map("two_fa_secret")
  twoFaEnabled    Boolean  @default(false) @map("two_fa_enabled")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  repProfile      RepProfile?
  clientProfile   ClientProfile?
  notifications   Notification[]
  auditLog        AuditLog[]
  assignedTasks   Task[]         @relation("AssignedTasks")
  createdTasks    Task[]         @relation("CreatedTasks")
  taskComments    TaskComment[]
  taskAuditTrail  TaskAuditLog[]
  assignedLeads   Lead[]
  crmActivities   CRMActivity[]
  incidents       Incident[]     @relation()
  qaScoresEvaluated QAScore[]    @relation("EvaluatedBy")

  @@map("users")
}

model RepProfile {
  id                  String    @id @default(cuid())
  userId              String    @unique @map("user_id")
  linkedinUrl         String    @map("linkedin_url")
  linkedinFollowers   Int       @default(0) @map("linkedin_followers")
  industry            String?
  locationCountry     String?   @map("location_country")
  locationCity        String?   @map("location_city")
  bio                 String?
  idVerified          Boolean   @default(false) @map("id_verified")
  idVerifiedAt        DateTime? @map("id_verified_at")
  idDocumentUrl       String?   @map("id_document_url")
  onboardingStep      Int       @default(1) @map("onboarding_step")
  twoFaConfirmed      Boolean   @default(false) @map("two_fa_confirmed")
  gologinProfileId    String?   @map("gologin_profile_id")
  bitbrowserId        String?   @map("bitbrowser_id")
  availabilityStatus  String    @default("available") @map("availability_status")
  maxClients          Int       @default(3) @map("max_clients")
  hourlyRateUsd       Decimal?  @map("hourly_rate_usd") @db.Decimal(8, 2)
  rating              Decimal   @default(0.00) @db.Decimal(3, 2)
  totalReviews        Int       @default(0) @map("total_reviews")
  trustScore          Int       @default(70) @map("trust_score")
  tier                RepTier   @default(BRONZE)
  createdAt           DateTime  @default(now()) @map("created_at")

  // Relations
  user                User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns           Campaign[]
  browserSessions     BrowserSession[]
  earnings            RepEarning[]
  prospects           Prospect[]
  qaScores            QAScore[]
  training            RepTraining[]
  dailyReports        DailyReport[]
  browserProfiles     BrowserProfile[]
  activityLogs        ActivityLog[]
  outreachSequences   OutreachSequence[]
  linkedInHealth      LinkedInHealthScore?
  repBadges           RepBadge[]

  @@map("rep_profiles")
}

model DailyReport {
  id              String   @id @default(cuid())
  repId           String   @map("rep_id")
  campaignId      String   @map("campaign_id")
  connectionsSent Int      @default(0) @map("connections_sent")
  messagesSent    Int      @default(0) @map("messages_sent")
  repliesReceived Int      @default(0) @map("replies_received")
  meetingsBooked  Int      @default(0) @map("meetings_booked")
  reportDate      DateTime @map("report_date")
  notes           String?
  status          String   @default("SUBMITTED") // SUBMITTED, LATE, MISSING
  createdAt       DateTime @default(now()) @map("created_at")

  // Relations
  rep             RepProfile @relation(fields: [repId], references: [id])
  campaign        Campaign   @relation(fields: [campaignId], references: [id])

  @@unique([repId, campaignId, reportDate])
  @@map("daily_reports")
}

enum RepTier {
  BRONZE
  SILVER
  GOLD
  ELITE
}

model ClientProfile {
  id              String  @id @default(cuid())
  userId          String  @unique @map("user_id")
  companyName     String? @map("company_name")
  website         String?
  industry        String?
  targetMarket    String? @map("target_market")
  billingEmail    String? @map("billing_email")
  plan            Plan    @default(STARTER)
  planStatus      String  @default("inactive") @map("plan_status")
  payfastToken    String? @map("payfast_token")
  createdAt       DateTime @default(now()) @map("created_at")

  // Relations
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns       Campaign[]
  subscriptions   Subscription[]
  earnings        RepEarning[]
  deals           Deal[]
  invoices        Invoice[]
  payments        Payment[]

  @@map("client_profiles")
}

model Campaign {
  id                String              @id @default(cuid())
  clientId          String              @map("client_id")
  repId             String?             @map("rep_id")
  name              String
  status            CampaignStatus      @default(DRAFT)
  type              CampaignType
  targetIcp         Json?               @map("target_icp")
  messageTemplates  Json?               @map("message_templates")
  dailyLimit        Int                 @default(40) @map("daily_limit")
  startDate         DateTime?           @map("start_date")
  endDate           DateTime?           @map("end_date")
  notes             String?
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  // Relations
  client            ClientProfile       @relation(fields: [clientId], references: [id])
  rep               RepProfile?         @relation(fields: [repId], references: [id])
  activities        CampaignActivity[]
  browserSessions   BrowserSession[]
  earnings          RepEarning[]
  prospects         Prospect[]
  qaScores          QAScore[]
  dailyReports      DailyReport[]
  activityLogs      ActivityLog[]
  outreachSequences OutreachSequence[]

  @@map("campaigns")
}

model CampaignActivity {
  id            String              @id @default(cuid())
  campaignId    String              @map("campaign_id")
  activityType  ActivityType        @map("activity_type")
  prospectName  String?             @map("prospect_name")
  prospectUrl  String?             @map("prospect_url")
  notes         String?
  occurredAt    DateTime            @default(now()) @map("occurred_at")

  // Relations
  campaign      Campaign            @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("campaign_activities")
}

model BrowserSession {
  id                  String              @id @default(cuid())
  repId               String              @map("rep_id")
  campaignId          String?             @map("campaign_id")
  provider            BrowserProvider
  externalProfileId  String?             @map("external_profile_id")
  status              SessionStatus       @default(IDLE)
  lastActiveAt        DateTime?           @map("last_active_at")
  sessionMeta         Json?               @map("session_meta")
  createdAt           DateTime            @default(now()) @map("created_at")

  // Relations
  rep                 RepProfile          @relation(fields: [repId], references: [id])
  campaign            Campaign?           @relation(fields: [campaignId], references: [id])

  @@map("browser_sessions")
}

model Subscription {
  id                  String    @id @default(cuid())
  clientId            String    @map("client_id")
  plan                Plan
  amountUsd           Decimal   @map("amount_usd") @db.Decimal(8, 2)
  status              String    @default("active")
  payfastPaymentId    String?   @map("payfast_payment_id")
  billingCycleStart   DateTime? @map("billing_cycle_start")
  billingCycleEnd     DateTime? @map("billing_cycle_end")
  nextBillingDate     DateTime? @map("next_billing_date")
  createdAt           DateTime  @default(now()) @map("created_at")

  // Relations
  client              ClientProfile @relation(fields: [clientId], references: [id])

  @@map("subscriptions")
}

model Payment {
  id          String   @id @default(cuid())
  clientId    String   @map("client_id")
  amountUsd   Decimal  @map("amount_usd") @db.Decimal(12, 2)
  currency    String
  provider    String
  providerId  String?  @map("provider_id")
  status      String
  createdAt   DateTime @default(now()) @map("created_at")

  client      ClientProfile @relation(fields: [clientId], references: [id])

  @@map("payments")
}

model RepEarning {
  id            String    @id @default(cuid())
  repId         String    @map("rep_id")
  campaignId    String    @map("campaign_id")
  clientId      String    @map("client_id")
  amountUsd     Decimal   @map("amount_usd") @db.Decimal(8, 2)
  periodStart   DateTime  @map("period_start")
  periodEnd     DateTime  @map("period_end")
  status        String    @default("pending")
  paidAt        DateTime? @map("paid_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  // Relations
  rep           RepProfile   @relation(fields: [repId], references: [id])
  campaign      Campaign     @relation(fields: [campaignId], references: [id])
  client        ClientProfile @relation(fields: [clientId], references: [id])

  @@map("rep_earnings")
}

model Notification {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  type        String
  title       String
  body        String
  read        Boolean  @default(false)
  actionUrl   String?  @map("action_url")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  user        User     @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model AuditLog {
  id          String   @id @default(cuid())
  actorId     String?  @map("actor_id")
  action      String
  entityType  String?  @map("entity_type")
  entityId    String?  @map("entity_id")
  metadata    Json?
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  actor       User?    @relation(fields: [actorId], references: [id])

  @@map("audit_log")
}

model Task {
  id              String      @id @default(cuid())
  title           String
  description     String?
  category        String      // Client / Rep / Compliance / Campaign / Finance / Internal / QA / Security
  priority        Priority    @default(MEDIUM)
  status          TaskStatus  @default(TODO)
  assignedToId    String      @map("assigned_to_id")
  createdById     String      @map("created_by_id")
  relatedToType   String?     @map("related_to_type") // client / rep / campaign / incident / payout
  relatedToId     String?     @map("related_to_id")
  dueDate         DateTime    @map("due_date")
  remindAt        DateTime?   @map("remind_at")
  completedAt     DateTime?   @map("completed_at")
  blockedReason   String?     @map("blocked_reason")
  isRecurring     Boolean     @default(false) @map("is_recurring")
  recurrenceRule  String?     @map("recurrence_rule")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  // Relations
  assignedTo      User        @relation("AssignedTasks", fields: [assignedToId], references: [id])
  createdBy       User        @relation("CreatedTasks", fields: [createdById], references: [id])
  comments        TaskComment[]
  auditTrail      TaskAuditLog[]

  @@map("tasks")
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String   @map("task_id")
  userId    String   @map("user_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@map("task_comments")
}

model TaskAuditLog {
  id          String   @id @default(cuid())
  taskId      String   @map("task_id")
  userId      String   @map("user_id")
  action      String
  before      Json?
  after       Json?
  timestamp   DateTime @default(now())

  // Relations
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id])

  @@map("task_audit_logs")
}

model Lead {
  id              String      @id @default(cuid())
  companyName     String      @map("company_name")
  contactName     String      @map("contact_name")
  email           String
  phone           String?
  linkedinUrl     String?     @map("linkedin_url")
  source          String
  industry        String
  companySize     String      @map("company_size")
  estRevenue      String?     @map("est_revenue")
  icpScore        Int?        @map("icp_score")
  pipelineStage   PipelineStage @default(NEW_LEAD) @map("pipeline_stage")
  assignedToId    String?     @map("assigned_to_id")
  nextAction      String?     @map("next_action")
  nextActionDate  DateTime?   @map("next_action_date")
  painPoints      String[]    @map("pain_points")
  outreachHistory String?     @map("outreach_history")
  budgetRange     String?     @map("budget_range")
  timeline        String?
  isDecisionMaker Boolean     @default(false) @map("is_decision_maker")
  notes           String?
  tags            String[]
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  // Relations
  assignedTo      User?       @relation(fields: [assignedToId], references: [id])
  activities      CRMActivity[]

  @@map("leads")
}

model Prospect {
  id              String      @id @default(cuid())
  campaignId      String      @map("campaign_id")
  repId           String      @map("rep_id")
  firstName       String      @map("first_name")
  lastName        String      @map("last_name")
  company         String
  jobTitle        String      @map("job_title")
  linkedinUrl     String      @map("linkedin_url")
  connectionStatus ConnectionStatus @default(NOT_SENT) @map("connection_status")
  messageStatus   MessageStatus @default(NOT_STARTED) @map("message_status")
  replySentiment  Sentiment?  @map("reply_sentiment")
  meetingBooked   Boolean     @default(false) @map("meeting_booked")
  meetingDate     DateTime?   @map("meeting_date")
  isDisqualified  Boolean     @default(false) @map("is_disqualified")
  disqualifyReason String?    @map("disqualify_reason")
  notes           String?
  tags            String[]
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  // Relations
  campaign          Campaign          @relation(fields: [campaignId], references: [id])
  rep               RepProfile        @relation(fields: [repId], references: [id])
  activities        CRMActivity[]
  deals             Deal[]
  outreachSequence  OutreachSequence?

  @@map("prospects")
}

model CRMActivity {
  id          String      @id @default(cuid())
  leadId      String?     @map("lead_id")
  prospectId  String?     @map("prospect_id")
  userId      String      @map("user_id")
  type        String      // STAGE_CHANGE, NOTE_ADDED, CALL_LOGGED, EMAIL_SENT, MEETING_BOOKED, PROPOSAL_SENT
  content     String
  metadata    Json?
  createdAt   DateTime    @default(now()) @map("created_at")

  // Relations
  lead        Lead?       @relation(fields: [leadId], references: [id])
  prospect    Prospect?   @relation(fields: [prospectId], references: [id])
  user        User        @relation(fields: [userId], references: [id])

  @@map("crm_activities")
}

model Deal {
  id              String      @id @default(cuid())
  prospectId      String      @map("prospect_id")
  clientId        String      @map("client_id")
  value           Decimal?    @db.Decimal(12, 2)
  status          String      @default("OPEN")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  // Relations
  prospect        Prospect    @relation(fields: [prospectId], references: [id])
  client          ClientProfile @relation(fields: [clientId], references: [id])

  @@map("deals")
}

model Incident {
  id            String      @id @default(cuid())
  type          String
  severity      Severity    @default(MEDIUM)
  relatedToType String?     @map("related_to_type")
  relatedToId   String?     @map("related_to_id")
  description   String
  status        String      @default("OPEN")
  reportedById  String      @map("reported_by_id")
  reportedAt    DateTime    @default(now()) @map("reported_at")
  resolvedAt    DateTime?   @map("resolved_at")
  resolution    String?

  // Relations
  reportedBy    User        @relation(fields: [reportedById], references: [id])

  @@map("incidents")
}

model QAScore {
  id            String      @id @default(cuid())
  campaignId    String      @map("campaign_id")
  repId         String      @map("rep_id")
  score         Int
  notes         String?
  evaluatedById String      @map("evaluated_by_id")
  createdAt     DateTime    @default(now()) @map("created_at")

  // Relations
  campaign      Campaign    @relation(fields: [campaignId], references: [id])
  rep           RepProfile  @relation(fields: [repId], references: [id])
  evaluatedBy   User        @relation("EvaluatedBy", fields: [evaluatedById], references: [id])

  @@map("qa_scores")
}

model RepTraining {
  id              String      @id @default(cuid())
  repId           String      @map("rep_id")
  moduleId        String      @map("module_id")
  status          String      @default("IN_PROGRESS")
  score           Int?
  attempts        Int         @default(1)
  lastAttemptAt   DateTime    @default(now()) @map("last_attempt_at")
  completedAt     DateTime?   @map("completed_at")

  // Relations
  rep             RepProfile  @relation(fields: [repId], references: [id])
  module          TrainingModule @relation(fields: [moduleId], references: [id])

  @@map("rep_training")
}

model TrainingModule {
  id          String      @id @default(cuid())
  title       String
  content     String
  order       Int
  createdAt   DateTime    @default(now()) @map("created_at")

  // Relations
  enrollments RepTraining[]

  @@map("training_modules")
}

model Invoice {
  id              String      @id @default(cuid())
  clientId        String      @map("client_id")
  amount          Decimal     @db.Decimal(12, 2)
  status          String      @default("PENDING")
  payfastPaymentId String?    @map("payfast_payment_id")
  dueDate         DateTime    @map("due_date")
  paidAt          DateTime?   @map("paid_at")
  pdfUrl          String?     @map("pdf_url")
  createdAt       DateTime    @default(now()) @map("created_at")

  // Relations
  client          ClientProfile @relation(fields: [clientId], references: [id])

  @@map("invoices")
}

model SystemSetting {
  key         String   @id
  value       Json
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

// Enums
enum UserRole {
  CLIENT
  REP
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  BANNED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum PipelineStage {
  NEW_LEAD
  QUALIFYING
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  WON_ONBOARDING
  ACTIVE_CLIENT
  CHURNED
  DISQUALIFIED
}

enum ConnectionStatus {
  NOT_SENT
  PENDING
  CONNECTED
  IGNORED
  WITHDRAWN
}

enum MessageStatus {
  NOT_STARTED
  MESSAGE_1_SENT
  MESSAGE_2_SENT
  MESSAGE_3_SENT
  REPLIED
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
  NOT_APPLICABLE
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Plan {
  STARTER
  PRO
  MANAGED
  ELITE
}

enum CampaignStatus {
  DRAFT
  PENDING_MATCH
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum CampaignType {
  CONNECTIONS
  DMS
  POSTS
  MIXED
}

enum ActivityType {
  CONNECTION_SENT
  CONNECTION_ACCEPTED
  DM_SENT
  DM_REPLIED
  POST_PUBLISHED
  MEETING_BOOKED
  ERROR
}

enum BrowserProvider {
  GOLOGIN
  BITBROWSER
  ADSPOWER
}

enum SessionStatus {
  IDLE
  LAUNCHING
  ACTIVE
  CLOSED
  ERROR
}

enum ProxyStatus {
  ACTIVE
  DEAD
  FLAGGED
  UNASSIGNED
}

enum SequenceStep {
  DAY_1
  DAY_4
  DAY_8
}

enum SequenceStatus {
  QUEUED
  IN_PROGRESS
  NO_RESPONSE
  REPLIED
  MEETING_BOOKED
  SKIPPED
}

enum MessageType {
  DIRECT
  CAMPAIGN_CHANNEL
  ESCALATION
}

// ─── Browser Profile ───────────────────────────────────────────────────────────
model BrowserProfile {
  id                  String          @id @default(cuid())
  repId               String          @map("rep_id")
  campaignId          String?         @map("campaign_id")
  provider            BrowserProvider
  externalProfileId   String?         @map("external_profile_id")
  linkedinAccountEmail String?        @map("linkedin_account_email")
  proxyId             String?         @map("proxy_id")
  lastLaunched        DateTime?       @map("last_launched")
  sessionStatus       SessionStatus   @default(IDLE) @map("session_status")
  warmupDay           Int             @default(0) @map("warmup_day")
  fingerprintConfig   Json?           @map("fingerprint_config")
  notes               String?
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  rep                 RepProfile      @relation(fields: [repId], references: [id])
  proxy               Proxy?          @relation(fields: [proxyId], references: [id])

  @@map("browser_profiles")
}

// ─── Proxy ─────────────────────────────────────────────────────────────────────
model Proxy {
  id                  String      @id @default(cuid())
  provider            String
  ipAddress           String      @map("ip_address")
  host                String
  port                Int
  username            String?
  password            String?
  country             String
  status              ProxyStatus @default(UNASSIGNED)
  lastChecked         DateTime?   @map("last_checked")
  rotationSchedule    String?     @map("rotation_schedule")
  notes               String?
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  browserProfiles     BrowserProfile[]

  @@map("proxies")
}

// ─── Activity Log (rep actions for auto-report) ────────────────────────────────
model ActivityLog {
  id          String      @id @default(cuid())
  repId       String      @map("rep_id")
  campaignId  String      @map("campaign_id")
  prospectId  String?     @map("prospect_id")
  actionType  ActivityType @map("action_type")
  metadata    Json?
  loggedAt    DateTime    @default(now()) @map("logged_at")

  rep         RepProfile  @relation(fields: [repId], references: [id])
  campaign    Campaign    @relation(fields: [campaignId], references: [id])

  @@map("activity_logs")
}

// ─── Outreach Sequence ─────────────────────────────────────────────────────────
model OutreachSequence {
  id              String          @id @default(cuid())
  prospectId      String          @map("prospect_id")
  repId           String          @map("rep_id")
  campaignId      String          @map("campaign_id")
  currentStep     SequenceStep    @default(DAY_1) @map("current_step")
  status          SequenceStatus  @default(QUEUED)
  day1SentAt      DateTime?       @map("day1_sent_at")
  day4SentAt      DateTime?       @map("day4_sent_at")
  day8SentAt      DateTime?       @map("day8_sent_at")
  day4DueAt       DateTime?       @map("day4_due_at")
  day8DueAt       DateTime?       @map("day8_due_at")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  prospect        Prospect        @relation(fields: [prospectId], references: [id])
  rep             RepProfile      @relation(fields: [repId], references: [id])
  campaign        Campaign        @relation(fields: [campaignId], references: [id])

  @@unique([prospectId])
  @@map("outreach_sequences")
}

// ─── LinkedIn Health Score ─────────────────────────────────────────────────────
model LinkedInHealthScore {
  id                        String      @id @default(cuid())
  repId                     String      @map("rep_id")
  score                     Int         @default(70)
  acceptanceRate7d          Decimal?    @map("acceptance_rate_7d") @db.Decimal(5, 2)
  daysSinceLastRestriction  Int?        @map("days_since_last_restriction")
  warmupDay                 Int         @default(0) @map("warmup_day")
  profileCompletenessScore  Int?        @map("profile_completeness_score")
  recentWarning             Boolean     @default(false) @map("recent_warning")
  connectionVelocityAlert   Boolean     @default(false) @map("connection_velocity_alert")
  lastCalculatedAt          DateTime    @default(now()) @map("last_calculated_at")
  createdAt                 DateTime    @default(now()) @map("created_at")

  rep                       RepProfile  @relation(fields: [repId], references: [id])

  @@unique([repId])
  @@map("linkedin_health_scores")
}

// ─── Internal Messaging ────────────────────────────────────────────────────────
model MessageThread {
  id              String          @id @default(cuid())
  type            MessageType     @default(DIRECT)
  campaignId      String?         @map("campaign_id")
  prospectId      String?         @map("prospect_id")
  subject         String?
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  participants    ThreadParticipant[]
  messages        InternalMessage[]

  @@map("message_threads")
}

model ThreadParticipant {
  id          String        @id @default(cuid())
  threadId    String        @map("thread_id")
  userId      String        @map("user_id")
  joinedAt    DateTime      @default(now()) @map("joined_at")

  thread      MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
  @@map("thread_participants")
}

model InternalMessage {
  id          String        @id @default(cuid())
  threadId    String        @map("thread_id")
  senderId    String        @map("sender_id")
  body        String
  read        Boolean       @default(false)
  createdAt   DateTime      @default(now()) @map("created_at")

  thread      MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@map("internal_messages")
}

// ─── Gamification ─────────────────────────────────────────────────────────────
model Badge {
  id          String      @id @default(cuid())
  key         String      @unique
  name        String
  description String
  icon        String
  createdAt   DateTime    @default(now()) @map("created_at")

  repBadges   RepBadge[]

  @@map("badges")
}

model RepBadge {
  id          String      @id @default(cuid())
  repId       String      @map("rep_id")
  badgeId     String      @map("badge_id")
  awardedAt   DateTime    @default(now()) @map("awarded_at")

  rep         RepProfile  @relation(fields: [repId], references: [id])
  badge       Badge       @relation(fields: [badgeId], references: [id])

  @@unique([repId, badgeId])
  @@map("rep_badges")
}
